---
import ThemeToggle from "@components/ThemeToggle.astro";
import { contact } from "@data/mock";

const navItems = [
  { href: "#work", label: "Work" },
  { href: "#about", label: "About" },
  { href: "#stack", label: "Stack" },
];
---

<header class="header">
  <div class="header__inner">
    <a
      class="header__brand"
      href="#top"
      aria-label="Joaquin Leimeter — home"
    >
      <span
        class="header__brand-mark"
        aria-hidden="true"></span>
      <span class="header__brand-name"
        >Joaquin Leimeter</span
      >
      <span class="header__brand-tag"
        >Full Stack Developer</span
      >
    </a>

    <nav
      class="header__nav"
      aria-label="Primary"
    >
      <ul class="header__nav-list">
        {
          navItems.map((item) => (
            <li>
              <a
                class="header__nav-link"
                href={item.href}
                data-nav-target={item.href.slice(
                  1,
                )}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header__actions">
      <ThemeToggle />
      <a
        class="header__cta"
        href={`mailto:${contact.email}`}
      >
        Let's Talk
      </a>
    </div>
  </div>
</header>

<script>
  const links = Array.from(
    document.querySelectorAll<HTMLAnchorElement>(
      ".header__nav-link",
    ),
  );
  const map = new Map<
    string,
    HTMLAnchorElement
  >();
  links.forEach((link) => {
    const target =
      link.dataset.navTarget;
    if (target) map.set(target, link);
  });

  const sections = Array.from(
    map.keys(),
  )
    .map((id) =>
      document.getElementById(id),
    )
    .filter(
      (el): el is HTMLElement =>
        el !== null,
    );

  if (sections.length > 0) {
    const observer =
      new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const link = map.get(
              entry.target.id,
            );
            if (!link) return;
            if (entry.isIntersecting) {
              links.forEach((l) =>
                l.removeAttribute(
                  "aria-current",
                ),
              );
              link.setAttribute(
                "aria-current",
                "true",
              );
            }
          });
        },
        {
          rootMargin:
            "-40% 0px -55% 0px",
          threshold: 0,
        },
      );

    sections.forEach((section) =>
      observer.observe(section),
    );
  }
</script>

<style lang="scss">
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: var(--space-400)
      var(--shell-padding-x);
    background: rgba(
      var(--color-canvas-rgb),
      0.85
    );
    backdrop-filter: blur(14px);
    border-bottom: 1px solid
      var(--color-border);
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-500);
    max-width: var(--shell-max-width);
    margin: 0 auto;
  }

  .header__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-300);
    font-size: var(--text-400);
  }

  .header__brand-mark {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: var(--radius-pill);
    background: var(
      --color-accent-strong
    );
  }

  .header__brand-name {
    font-weight: 700;
    color: var(--color-text);
  }

  .header__brand-tag {
    color: var(--color-text-subtle);
    font-size: var(--text-300);
  }

  .header__nav {
    margin-left: auto;
  }

  .header__nav-list {
    display: flex;
    gap: var(--space-500);
  }

  .header__nav-link {
    color: var(--color-text-muted);
    font-size: var(--text-400);
    transition: color 0.2s ease;

    &:hover,
    &[aria-current="true"] {
      color: var(--color-text);
    }
  }

  .header__actions {
    display: inline-flex;
    align-items: center;
    gap: var(--space-300);
  }

  .header__cta {
    padding: 0.55rem 1.1rem;
    border-radius: var(--radius-pill);
    background: var(
      --color-accent-strong
    );
    color: #ffffff;
    font-weight: 600;
    font-size: var(--text-300);
    box-shadow: 0 8px 24px
      rgba(
        var(--color-accent-strong-rgb),
        0.35
      );
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;

    &:hover {
      transform: translateY(-1px);
      box-shadow: 0 12px 28px
        rgba(
          var(
            --color-accent-strong-rgb
          ),
          0.45
        );
    }
  }

  @media (max-width: 640px) {
    .header__inner {
      flex-wrap: wrap;
      gap: var(--space-300);
    }

    .header__brand-tag {
      display: none;
    }

    .header__nav {
      order: 3;
      flex-basis: 100%;
      margin-left: 0;
    }

    .header__nav-list {
      gap: var(--space-400);
    }

    .header__actions {
      margin-left: auto;
    }
  }
</style>
