---
import Button from "./button.astro";
---

<header class="header" id="site-header">
  <div
    class="header__inner section-wrapper"
  >
    <a
      href="/"
      class="header__brand color-white"
    >
      <div class="header__monogram">
        JL
      </div>
      <span class="weight-bold"
        >Joaquin Leimeter</span
      >
    </a>

    <nav>
      <ul
        class="header__nav"
        role="list"
      >
        <li>
          <Button
            text="Projects"
            href="#projects"
            variant="link"
          />
        </li>
        <li>
          <Button
            text="Technologies"
            href="#expertise"
            variant="link"
          />
        </li>
        <li>
          <Button
            text="Contact"
            href="/contact"
            variant="link"
          />
        </li>
        <li>
          <Button
            text="Hire Me"
            href="#hero"
            glow
            pill
          />
        </li>
      </ul>
    </nav>
  </div>
</header>

<style lang="scss">
  @use "../css/config" as *;

  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 2rem;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background 0.35s ease,
      border-color 0.35s ease,
      backdrop-filter 0.35s ease;
  }

  .header--scrolled {
    background: rgba(14, 11, 4, 0.88);
    backdrop-filter: blur(20px)
      saturate(1.4);
    -webkit-backdrop-filter: blur(20px)
      saturate(1.4);
    border-bottom-color: rgba(
      255,
      255,
      255,
      0.05
    );
  }

  .header__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 68px;
    flex-wrap: nowrap;
  }

  .header__brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    font-size: 0.9375rem;
  }

  .header__monogram {
    width: 30px;
    height: 30px;
    border-radius: 0.5rem;
    background: map-get(
      $gorko-colors,
      "primary"
    );
    display: grid;
    place-items: center;
    font-size: 0.6875rem;
    font-weight: 800;
    color: #fff;
    box-shadow: 0 4px 12px
      rgba(
        map-get(
          $gorko-colors,
          "primary"
        ),
        0.4
      );
    flex-shrink: 0;
  }

  .header__nav {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 1.75rem;
    padding: 0;
  }
</style>

<script>
  const header =
    document.getElementById(
      "site-header",
    );
  if (header) {
    const fn = () => {
      if (window.scrollY > 50) {
        header.classList.add(
          "header--scrolled",
        );
      } else {
        header.classList.remove(
          "header--scrolled",
        );
      }
    };
    window.addEventListener(
      "scroll",
      fn,
      { passive: true },
    );
    fn();
  }
</script>
