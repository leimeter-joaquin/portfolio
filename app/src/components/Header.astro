---
import Button from "./button.astro";
---

<header class="header" id="site-header">
  <div
    class="header__inner section-wrapper"
  >
    <a
      href="/"
      class="header__brand color-white"
    >
      <div class="header__monogram">
        JL
      </div>
      <span class="weight-bold"
        >Joaquin Leimeter</span
      >
    </a>

    <nav>
      <ul
        class="header__nav"
        role="list"
      >
        <li>
          <Button
            text="Projects"
            href="#projects"
            variant="link"
          />
        </li>
        <li>
          <Button
            text="Technologies"
            href="#expertise"
            variant="link"
          />
        </li>
        <li>
          <Button
            text="Contact"
            href="/contact"
            variant="link"
          />
        </li>
        <li>
          <button
            id="theme-toggle"
            class="header__theme-toggle"
            aria-label="Toggle light/dark mode"
          >
            <!-- Sun: visible in dark mode, click switches to light -->
            <svg
              class="theme-icon theme-icon--sun"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle
                cx="12"
                cy="12"
                r="5"></circle>
              <line
                x1="12"
                y1="1"
                x2="12"
                y2="3"></line>
              <line
                x1="12"
                y1="21"
                x2="12"
                y2="23"></line>
              <line
                x1="4.22"
                y1="4.22"
                x2="5.64"
                y2="5.64"></line>
              <line
                x1="18.36"
                y1="18.36"
                x2="19.78"
                y2="19.78"></line>
              <line
                x1="1"
                y1="12"
                x2="3"
                y2="12"></line>
              <line
                x1="21"
                y1="12"
                x2="23"
                y2="12"></line>
              <line
                x1="4.22"
                y1="19.78"
                x2="5.64"
                y2="18.36"></line>
              <line
                x1="18.36"
                y1="5.64"
                x2="19.78"
                y2="4.22"></line>
            </svg>
            <!-- Moon: visible in light mode, click switches to dark -->
            <svg
              class="theme-icon theme-icon--moon"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
              ></path>
            </svg>
          </button>
        </li>
        <li>
          <Button
            text="Hire Me"
            href="#hero"
            glow
            pill
          />
        </li>
      </ul>
    </nav>
  </div>
</header>

<style lang="scss">
  @use "../css/config" as *;

  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 2rem;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background 0.35s ease,
      border-color 0.35s ease,
      backdrop-filter 0.35s ease;
  }

  .header--scrolled {
    background: var(
      --header-frosted-bg
    );
    backdrop-filter: blur(20px)
      saturate(1.4);
    -webkit-backdrop-filter: blur(20px)
      saturate(1.4);
    border-bottom-color: var(
      --header-frosted-border
    );
  }

  .header__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 68px;
    flex-wrap: nowrap;
  }

  .header__brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    font-size: 0.9375rem;
  }

  .header__monogram {
    width: 30px;
    height: 30px;
    border-radius: 0.5rem;
    background: var(--accent);
    display: grid;
    place-items: center;
    font-size: 0.6875rem;
    font-weight: 800;
    color: #fff;
    box-shadow: 0 4px 12px
      rgba(var(--accent-rgb), 0.4);
    flex-shrink: 0;
  }

  .header__nav {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 1.75rem;
    padding: 0;
  }

  .header__theme-toggle {
    background: none;
    border: 1px solid
      var(--glass-border);
    border-radius: 0.5rem;
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    cursor: pointer;
    color: var(--color-text-muted);
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;

    &:hover {
      color: var(--accent);
      border-color: rgba(
        var(--accent-rgb),
        0.35
      );
      background: rgba(
        var(--accent-rgb),
        0.07
      );
    }
  }

  // Icon visibility controlled by JS (avoids hydration flicker)
  .theme-icon {
    display: none;
  }
</style>

<script>
  const html = document.documentElement;
  const btn = document.getElementById(
    "theme-toggle",
  );
  const sunIcon = btn?.querySelector(
    ".theme-icon--sun",
  ) as HTMLElement | null;
  const moonIcon = btn?.querySelector(
    ".theme-icon--moon",
  ) as HTMLElement | null;

  function applyTheme(theme: string) {
    html.dataset.theme = theme;
    localStorage.setItem(
      "theme",
      theme,
    );
    if (sunIcon && moonIcon) {
      const isDark = theme !== "light";
      sunIcon.style.display = isDark
        ? "block"
        : "none";
      moonIcon.style.display = isDark
        ? "none"
        : "block";
    }
  }

  // Init icon on load
  applyTheme(
    html.dataset.theme || "dark",
  );

  btn?.addEventListener("click", () => {
    const targetTheme =
      html.dataset.theme === "light"
        ? "dark"
        : "light";

    // Pin the clip-path origin to the toggle button centre
    const rect =
      btn.getBoundingClientRect();
    html.style.setProperty(
      "--ripple-x",
      `${rect.left + rect.width / 2}px`,
    );
    html.style.setProperty(
      "--ripple-y",
      `${rect.top + rect.height / 2}px`,
    );

    // View Transitions API: captures old/new snapshots and clips the
    // new-theme snapshot to an expanding circle — real colors reveal as it sweeps.
    if (
      "startViewTransition" in document
    ) {
      document.startViewTransition(
        () => {
          applyTheme(targetTheme);
        },
      );
    } else {
      applyTheme(targetTheme);
    }
  });

  // Frosted-on-scroll
  const header =
    document.getElementById(
      "site-header",
    );
  if (header) {
    const fn = () => {
      header.classList.toggle(
        "header--scrolled",
        window.scrollY > 50,
      );
    };
    window.addEventListener(
      "scroll",
      fn,
      {
        passive: true,
      },
    );
    fn();
  }
</script>
