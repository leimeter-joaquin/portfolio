---
import {
  heroCopy,
  contact,
} from "@data/mock";

const {
  eyebrow,
  headline,
  accentPhrase,
  bio,
} = heroCopy;
const idx = headline.indexOf(
  accentPhrase,
);
const before =
  idx >= 0
    ? headline.slice(0, idx)
    : headline;
const after =
  idx >= 0
    ? headline.slice(
        idx + accentPhrase.length,
      )
    : "";
const accent =
  idx >= 0 ? accentPhrase : "";
---

<section id="about" class="hero">
  <div class="hero__inner">
    <div class="hero__main">
      <p class="hero__eyebrow">
        {eyebrow}
      </p>
      <h1
        class="hero__headline"
        data-headline
      >
        {before}<span
          class="hero__accent"
          >{accent}</span
        >{after}
      </h1>
      <p class="hero__bio">{bio}</p>
    </div>

    <aside
      id="stack"
      class="hero__meta"
    >
      <dl class="hero__meta-list">
        <div class="hero__meta-row">
          <dt>Location</dt>
          <dd>{contact.location}</dd>
        </div>
        <div class="hero__meta-row">
          <dt>Email</dt>
          <dd>
            <a
              href={`mailto:${contact.email}`}
              >{contact.email}</a
            >
          </dd>
        </div>
        <div class="hero__meta-row">
          <dt>GitHub</dt>
          <dd>
            <a
              href={contact.github}
              rel="noopener noreferrer"
              target="_blank"
              >github.com/leimeter-joaquin</a
            >
          </dd>
        </div>
        <div class="hero__meta-row">
          <dt>LinkedIn</dt>
          <dd>
            <a
              href={contact.linkedin}
              rel="noopener noreferrer"
              target="_blank"
              >linkedin.com/in/joaquinleimeter</a
            >
          </dd>
        </div>
      </dl>
    </aside>
  </div>
</section>

<script>
  import {
    animate,
    stagger,
  } from "animejs";

  const headline =
    document.querySelector<HTMLElement>(
      "[data-headline]",
    );
  if (
    headline &&
    !window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches
  ) {
    const text =
      headline.textContent ?? "";
    const accentEl =
      headline.querySelector(
        ".hero__accent",
      );
    const accentText =
      accentEl?.textContent ?? "";
    const words = text.split(/(\s+)/);
    headline.innerHTML = words
      .map((token) => {
        if (/^\s+$/.test(token))
          return token;
        const isAccent =
          accentText.includes(token) &&
          accentText.length > 0;
        const cls = isAccent
          ? "hero__word hero__word--accent"
          : "hero__word";
        return `<span class="${cls}">${token}</span>`;
      })
      .join("");

    animate(".hero__word", {
      opacity: [0, 1],
      translateY: [16, 0],
      delay: stagger(60),
      duration: 700,
      easing:
        "cubicBezier(0.22, 1, 0.36, 1)",
    });
  }
</script>

<style lang="scss">
  .hero {
    padding: var(--space-800)
      var(--shell-padding-x)
      var(--space-700);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: var(--space-700);
    max-width: var(--shell-max-width);
    margin: 0 auto;
  }

  .hero__eyebrow {
    color: var(--color-text-subtle);
    font-size: var(--text-300);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: var(--space-500);
  }

  .hero__headline {
    font-size: var(--text-display);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-text);
    max-width: 18ch;
  }

  .hero__headline :global(.hero__word) {
    display: inline-block;
    will-change: opacity, transform;
  }

  .hero__accent,
  .hero__headline
    :global(.hero__word--accent) {
    color: var(--color-accent-strong);
  }

  .hero__bio {
    margin-top: var(--space-500);
    max-width: 52ch;
    color: var(--color-text-muted);
    font-size: var(--text-400);
    line-height: 1.65;
  }

  .hero__meta {
    align-self: start;
    padding-top: calc(
      var(--space-500) + 1.5rem
    );
  }

  .hero__meta-list {
    display: grid;
    gap: var(--space-300);
  }

  .hero__meta-row {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: var(--space-300);
    font-size: var(--text-300);
  }

  .hero__meta-row dt {
    color: var(--color-text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .hero__meta-row dd {
    color: var(--color-text);
    margin: 0;
    word-break: break-word;
  }

  .hero__meta-row a {
    color: inherit;
    border-bottom: 1px solid
      var(--color-border-strong);
    transition: border-color 0.2s ease;

    &:hover {
      border-color: var(
        --color-accent-strong
      );
    }
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-600);
    }

    .hero__meta {
      padding-top: 0;
    }
  }
</style>
