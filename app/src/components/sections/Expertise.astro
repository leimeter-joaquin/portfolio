---
import Button from "../button.astro";
import content from "@portfolio/content/data";

const { techs } = content;
---

<section id="expertise" class="expertise">
  <div class="expertise__inner section-wrapper">
    <div class="expertise__header">
      <div>
        <h2 class="color-white weight-bold">Technical Expertise</h2>
        <p class="color-muted">Building scalable solutions with modern tools.</p>
      </div>
      <Button text="See full resume →" href="/resume" variant="link" />
    </div>

    <ul class="expertise__grid" role="list">
      {techs.map((tech) => (
        <li class="expertise__card bg-surface">
          <div class="expertise__card-header">
            <span class="expertise__card-icon color-primary">{tech.name[0]}</span>
            <span class="expertise__badge color-primary">{tech.proficiencyBadge}</span>
          </div>
          <div class="expertise__card-body">
            <h3 class="color-white weight-bold">{tech.name}</h3>
            <p class="color-muted">{tech.description}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .expertise {
    background: #0f1424;
    border-top: 1px solid rgba(30, 37, 64, 0.5);
    border-bottom: 1px solid rgba(30, 37, 64, 0.5);
  }

  .expertise__inner {
    padding-block: 5rem;
  }

  .expertise__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
  }

  .expertise__header h2 {
    font-size: 2.25rem;
    letter-spacing: -0.025em;
  }

  .expertise__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    padding: 0;
  }

  .expertise__card {
    display: grid;
    gap: 1.25rem;
    padding: 1.5625rem;
    border-radius: 1rem;
    border: 1px solid #1e2540;
  }

  .expertise__card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .expertise__badge {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: rgba(219, 48, 105, 0.1);
    border: 1px solid rgba(219, 48, 105, 0.2);
    border-radius: 9999px;
    padding: 0.2rem 0.6rem;
  }

  .expertise__card-icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 0.5rem;
    background: rgba(219, 48, 105, 0.1);
    font-size: 1.25rem;
  }

  .expertise__card-body {
    display: grid;
    gap: 0.5rem;
  }

  .expertise__card-body h3 {
    font-size: 1.25rem;
  }

  .expertise__card-body p {
    font-size: 0.875rem;
    line-height: 1.625;
  }
</style>
