---
import Button from "../button.astro";
import content from "@portfolio/content/data";

const imageMap: Record<
  string,
  { src: string }
> = {};

const { projects } = content;
---

<section
  id="projects"
  class="projects section-wrapper"
>
  <div class="projects__header">
    <h2 class="color-white weight-bold">
      Selected Works
    </h2>
    <p class="color-muted">
      A glimpse into my recent
      development projects.
    </p>
  </div>

  <ul
    class="projects__grid"
    role="list"
  >
    {
      projects.map((project, i) => {
        const image =
          imageMap[project.slug];
        return (
          <li
            class="projects__card bg-surface"
            data-delay={i * 100}
          >
            {image && (
              <div class="projects__card-image">
                <img
                  src={image.src}
                  alt={project.title}
                />
                <div class="projects__card-gradient" />
              </div>
            )}
            <div
              class:list={[
                "projects__card-body",
                !image &&
                  "projects__card-body--no-image",
              ]}
            >
              <div class="projects__card-tags">
                {[
                  ...project.tags,
                  ...project.stack,
                ].map((tag, j) => (
                  <span
                    class:list={[
                      "projects__tag",
                      j === 0
                        ? "projects__tag--primary"
                        : "projects__tag--neutral",
                    ]}
                  >
                    {tag}
                  </span>
                ))}
              </div>
              <h3 class="color-white weight-bold">
                {project.title}
              </h3>
              <p class="color-secondary">
                {project.highlights[0]}
              </p>
              <div class="projects__card-cta color-primary">
                View project →
              </div>
            </div>
          </li>
        );
      })
    }
  </ul>

  <div class="projects__footer">
    <a
      href="/projects"
      class="projects__view-all color-white weight-bold"
      >View All Projects</a
    >
  </div>
</section>

<style lang="scss">
  @use "../../css/config" as *;

  .projects {
    padding-block: 5.625rem;
  }

  .projects__header {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 3rem;
    opacity: 0;
  }

  .projects__header h2 {
    font-size: clamp(
      1.875rem,
      4vw,
      2.625rem
    );
    letter-spacing: -0.04em;
  }

  .projects__grid {
    display: grid;
    grid-template-columns: repeat(
      auto-fit,
      minmax(300px, 1fr)
    );
    gap: 1.25rem;
    padding: 0;
  }

  .projects__card {
    border-radius: 1.125rem;
    border: 1px solid
      map-get($gorko-colors, "border");
    overflow: hidden;
    position: relative;
    cursor: pointer;
    opacity: 0;
    transform: translateY(24px);
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;

    &:hover {
      border-color: rgba(
        map-get(
          $gorko-colors,
          "primary"
        ),
        0.4
      );
      transform: translateY(-4px);
      box-shadow: 0 16px 48px
        rgba(
          map-get(
            $gorko-colors,
            "primary"
          ),
          0.12
        );
    }
  }

  .projects__card-image {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .projects__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .projects__card-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(
          map-get(
            $gorko-colors,
            "background"
          ),
          0.9
        )
        0%,
      rgba(
          map-get(
            $gorko-colors,
            "background"
          ),
          0.4
        )
        50%,
      transparent 100%
    );
    opacity: 0.8;
  }

  .projects__card-body {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: grid;
    gap: 0.5rem;
    padding: 1.5rem;
  }

  .projects__card-body--no-image {
    position: static;
    padding: 1.75rem;
  }

  .projects__card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4375rem;
    margin-bottom: 0.25rem;
  }

  .projects__tag {
    font-size: 0.6875rem;
    font-weight: 700;
    padding: 0.1875rem 0.625rem;
    border-radius: 0.3125rem;
    white-space: nowrap;
  }

  .projects__tag--primary {
    background: rgba(
      map-get($gorko-colors, "primary"),
      0.18
    );
    color: map-get(
      $gorko-colors,
      "primary"
    );
  }

  .projects__tag--neutral {
    background: rgba(
      255,
      255,
      255,
      0.07
    );
    color: rgba(255, 255, 255, 0.55);
  }

  .projects__card-body h3 {
    font-size: 1.1875rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .projects__card-body p {
    font-size: 0.875rem;
    line-height: 1.7;
    overflow-wrap: break-word;
  }

  .projects__card-cta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 700;
    margin-top: 0.25rem;
  }

  .projects__footer {
    display: grid;
    place-items: center;
    margin-top: 2.75rem;
  }

  .projects__view-all {
    text-decoration: none;
    font-size: 0.9375rem;
    padding-bottom: 0.375rem;
    border-bottom: 2px solid
      map-get($gorko-colors, "primary");
    transition: opacity 0.2s ease;

    &:hover {
      opacity: 0.7;
    }
  }
</style>

<script>
  import {
    animate,
    stagger,
  } from "animejs";

  const section =
    document.getElementById("projects");
  if (section) {
    let headerRevealed = false;
    let cardsRevealed = false;

    const headerObs =
      new IntersectionObserver(
        ([entry]) => {
          if (
            entry.isIntersecting &&
            !headerRevealed
          ) {
            headerRevealed = true;
            animate(
              ".projects__header",
              {
                opacity: [0, 1],
                y: [20, 0],
                duration: 600,
                ease: "outCubic",
              },
            );
            headerObs.disconnect();
          }
        },
        { threshold: 0.08 },
      );

    const cardsObs =
      new IntersectionObserver(
        ([entry]) => {
          if (
            entry.isIntersecting &&
            !cardsRevealed
          ) {
            cardsRevealed = true;
            animate(".projects__card", {
              opacity: [0, 1],
              y: [24, 0],
              duration: 600,
              ease: "outCubic",
              delay: stagger(100),
            });
            cardsObs.disconnect();
          }
        },
        { threshold: 0.05 },
      );

    const header =
      section.querySelector(
        ".projects__header",
      );
    const grid = section.querySelector(
      ".projects__grid",
    );
    if (header)
      headerObs.observe(header);
    if (grid) cardsObs.observe(grid);
  }
</script>
