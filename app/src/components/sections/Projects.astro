---
import ProjectCard from "@components/ProjectCard.astro";
import { projects } from "@data/mock";

const featured = projects.find(
  (p) => p.featured,
);
const secondaries = projects
  .filter((p) => !p.featured)
  .slice(0, 2);
---

<section id="work" class="projects">
  <div class="projects__inner">
    <header class="projects__header">
      <p class="projects__eyebrow">
        Selected work
      </p>
      <div
        class="projects__heading-row"
      >
        <h2 class="projects__title">
          Things I've shipped.
        </h2>
        <a
          class="projects__more"
          href="#work">All projects →</a
        >
      </div>
    </header>

    <ul class="projects__grid">
      {
        featured && (
          <li class="projects__row projects__row--featured">
            <ProjectCard
              project={featured}
              featured
            />
          </li>
        )
      }
      {
        secondaries.length > 0 && (
          <li class="projects__row projects__row--secondary">
            <ul class="projects__pair">
              {secondaries.map((p) => (
                <li>
                  <ProjectCard
                    project={p}
                  />
                </li>
              ))}
            </ul>
          </li>
        )
      }
    </ul>
  </div>
</section>

<style lang="scss">
  .projects {
    padding: var(--space-800)
      var(--shell-padding-x);
    background: var(
      --color-surface-muted
    );
  }

  .projects__inner {
    max-width: var(--shell-max-width);
    margin: 0 auto;
  }

  .projects__eyebrow {
    color: var(--color-text-subtle);
    font-size: var(--text-300);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: var(--space-300);
  }

  .projects__heading-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-400);
    margin-bottom: var(--space-600);
  }

  .projects__title {
    font-size: var(--text-800);
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .projects__more {
    color: var(--color-accent-strong);
    font-size: var(--text-300);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .projects__grid {
    display: grid;
    gap: var(--space-500);
  }

  .projects__pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-500);
  }

  @media (max-width: 720px) {
    .projects__pair {
      grid-template-columns: 1fr;
    }
    .projects__heading-row {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
