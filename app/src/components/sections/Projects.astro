---
import Button from "../button.astro";
import ecommerceImg from "../../assets/projects/ecommerce.png";
import saasImg from "../../assets/projects/saas.png";

const projects = [
  {
    title: "E-Commerce Analytics Platform",
    description:
      "A comprehensive dashboard for tracking sales metrics, user behavior, and inventory management in real-time.",
    tags: ["React", "Tailwind"],
    image: ecommerceImg,
  },
  {
    title: "SaaS Infrastructure Manager",
    description:
      "A cloud resource management tool allowing developers to provision and monitor server instances easily.",
    tags: ["Vue.js", "AWS"],
    image: saasImg,
  },
];
---

<section id="projects" class="projects section-wrapper">
  <div class="projects__header">
    <h2 class="color-white weight-bold">Selected Works</h2>
    <p class="color-muted">A glimpse into my recent development projects.</p>
  </div>

  <ul class="projects__grid" role="list">
    {projects.map((project, i) => (
      <li class="projects__card bg-surface">
        <div class="projects__card-image">
          <img src={project.image.src} alt={project.title} />
          <div class="projects__card-gradient"></div>
        </div>
        <div class="projects__card-body">
          <div class="projects__card-tags">
            {project.tags.map((tag, j) => (
              <span class:list={["projects__tag color-white", j === 0 ? "projects__tag--primary" : "projects__tag--neutral"]}>{tag}</span>
            ))}
          </div>
          <h3 class="color-white weight-bold">{project.title}</h3>
          <p class="color-secondary">{project.description}</p>
        </div>
      </li>
    ))}
  </ul>

  <div class="projects__footer">
    <a href="/projects" class="projects__view-all color-white weight-bold">View All Projects</a>
  </div>
</section>

<style>
  .projects {
    padding-block: 5rem;
  }

  .projects__header {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }

  .projects__header h2 {
    font-size: 2.25rem;
    letter-spacing: -0.025em;
  }

  .projects__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    padding: 0;
  }

  .projects__card {
    border-radius: 0.75rem;
    border: 1px solid rgba(30, 37, 64, 0.5);
    overflow: hidden;
    position: relative;
  }

  .projects__card-image {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .projects__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .projects__card-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(12, 18, 35, 0.9) 0%,
      rgba(12, 18, 35, 0.4) 50%,
      rgba(12, 18, 35, 0) 100%
    );
    opacity: 0.8;
  }

  .projects__card-body {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: grid;
    gap: 0.5rem;
    padding: 1.5rem;
  }

  .projects__card-tags {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .projects__tag {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    backdrop-filter: blur(2px);
  }

  .projects__tag--primary {
    background: rgba(219, 48, 105, 0.2);
  }

  .projects__tag--neutral {
    background: rgba(255, 255, 255, 0.1);
  }

  .projects__card-body h3 {
    font-size: 1.25rem;
  }

  .projects__card-body p {
    font-size: 0.875rem;
    line-height: 1.45;
  }

  .projects__footer {
    display: grid;
    place-items: center;
    margin-top: 2.5rem;
  }

  .projects__view-all {
    text-decoration: none;
    font-size: 1rem;
    padding-bottom: 0.375rem;
    border-bottom: 2px solid #db3069;
  }
</style>
