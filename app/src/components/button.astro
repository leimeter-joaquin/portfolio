---
interface Props {
  text: string;
  href?: string;
  type?: "button" | "submit" | "reset";
  variant?: "primary" | "secondary" | "link";
}

const variantClasses: Record<string, string> = {
  primary: "bg-primary color-background",
  secondary: "bg-secondary color-background",
  link: "color-primary",
};

const {
  text,
  href,
  type = "button",
  variant = "primary",
} = Astro.props;

const classes = `button ${variantClasses[variant] ?? ""}`;
---

{
  href ? (
    <a class={classes} href={href} data-variant={variant}>
      {text}
    </a>
  ) : (
    <button class={classes} type={type} data-variant={variant}>
      {text}
    </button>
  )
}
<style>
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.25rem;
    border: 0;
    border-radius: 0.5rem;
    text-decoration: none;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
    font: inherit;
  }

  .button:hover {
    opacity: 0.9;
  }

  .button:active {
    transform: translateY(1px);
  }

  .button[data-variant="link"] {
    background: transparent;
    padding: 0;
    border-radius: 0;
  }
</style>
