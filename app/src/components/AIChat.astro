---

---

<div class="ai-chat">
  <div class="ai-chat__box">
    <div
      id="ai-chat-thread"
      class="ai-chat__thread"
      aria-live="polite"
      aria-atomic="false"
    >
    </div>
    <div class="ai-chat__input-area">
      <form
        id="ai-chat-form"
        class="ai-chat__form"
        novalidate
      >
        <span
          class="ai-chat__prompt color-muted"
          aria-hidden="true">{">"}</span
        >
        <input
          id="ai-chat-input"
          class="ai-chat__input color-white"
          type="text"
          placeholder="Ask me anything…"
          autocomplete="off"
          maxlength={500}
        />
        <button
          id="ai-chat-submit"
          class="ai-chat__submit color-muted"
          type="submit"
        >
          ↵
        </button>
        {
          import.meta.env.DEV && (
            <button
              id="ai-chat-clear"
              class="ai-chat__clear color-muted"
              type="button"
              title="Clear conversation (dev only)"
            >
              ×
            </button>
          )
        }
      </form>
    </div>
  </div>
  <p
    id="ai-chat-counter"
    class="ai-chat__counter color-muted"
  >
  </p>
</div>

<script>
  const API_URL =
    (import.meta.env.PUBLIC_API_URL as
      | string
      | undefined) ??
    "http://localhost:3001";
  const MAX_QUESTIONS = 3;
  const STORAGE_KEY = "ai-chat-history";

  type Message = {
    role: "user" | "ai";
    text: string;
    isError?: boolean;
  };

  const form = document.getElementById(
    "ai-chat-form",
  ) as HTMLFormElement;
  const input = document.getElementById(
    "ai-chat-input",
  ) as HTMLInputElement;
  const submitBtn =
    document.getElementById(
      "ai-chat-submit",
    ) as HTMLButtonElement;
  const threadEl =
    document.getElementById(
      "ai-chat-thread",
    ) as HTMLElement;
  const counterEl =
    document.getElementById(
      "ai-chat-counter",
    ) as HTMLElement;
  const clearBtn =
    document.getElementById(
      "ai-chat-clear",
    ) as HTMLButtonElement | null;

  let questionsRemaining =
    MAX_QUESTIONS;
  let limitReached = false;
  let typewriterTimer: ReturnType<
    typeof setInterval
  > | null = null;

  function scrollToBottom() {
    threadEl.scrollTop =
      threadEl.scrollHeight;
  }

  function createBubble(
    role: "user" | "ai",
    isError = false,
  ): HTMLElement {
    const el =
      document.createElement("div");
    el.className = [
      "ai-chat__bubble",
      role === "user"
        ? "ai-chat__bubble--user"
        : "ai-chat__bubble--ai",
      isError
        ? "ai-chat__bubble--error"
        : "",
    ]
      .filter(Boolean)
      .join(" ");
    return el;
  }

  function appendUserBubble(
    text: string,
  ) {
    const el = createBubble("user");
    el.textContent = text;
    threadEl.appendChild(el);
    scrollToBottom();
  }

  function appendThinkingBubble(): HTMLElement {
    const el = createBubble("ai");
    el.classList.add(
      "ai-chat__bubble--thinking",
    );
    el.innerHTML = `<span class="ai-chat__dots"><span></span><span></span><span></span></span>`;
    threadEl.appendChild(el);
    scrollToBottom();
    return el;
  }

  function typewriteInto(
    el: HTMLElement,
    text: string,
    isError = false,
    onComplete?: () => void,
  ) {
    if (typewriterTimer !== null) {
      clearInterval(typewriterTimer);
      typewriterTimer = null;
    }
    el.classList.remove(
      "ai-chat__bubble--thinking",
    );
    if (isError)
      el.classList.add(
        "ai-chat__bubble--error",
      );
    el.textContent = "";

    let i = 0;
    typewriterTimer = setInterval(
      () => {
        el.textContent += text[i++];
        scrollToBottom();
        if (i >= text.length) {
          clearInterval(
            typewriterTimer!,
          );
          typewriterTimer = null;
          onComplete?.();
        }
      },
      18,
    );
  }

  function saveHistory(
    messages: Message[],
  ) {
    try {
      sessionStorage.setItem(
        STORAGE_KEY,
        JSON.stringify(messages),
      );
    } catch {}
  }

  function loadHistory(): Message[] {
    try {
      return JSON.parse(
        sessionStorage.getItem(
          STORAGE_KEY,
        ) ?? "[]",
      ) as Message[];
    } catch {
      return [];
    }
  }

  function renderHistoryMessage(
    msg: Message,
  ) {
    const el = createBubble(
      msg.role,
      msg.isError,
    );
    el.textContent = msg.text;
    threadEl.appendChild(el);
  }

  const history = loadHistory();
  for (const msg of history) {
    renderHistoryMessage(msg);
  }
  if (history.length > 0)
    scrollToBottom();

  function setLoading(
    loading: boolean,
  ) {
    if (loading) {
      input.disabled = true;
      submitBtn.disabled = true;
      submitBtn.textContent = "…";
    } else {
      submitBtn.textContent = "↵";
      if (!limitReached) {
        input.disabled = false;
        submitBtn.disabled = false;
      }
    }
  }

  function updateCounter(
    remaining: number,
  ) {
    questionsRemaining = remaining;
    if (remaining <= 0) {
      limitReached = true;
      counterEl.textContent = `You've used all ${MAX_QUESTIONS} questions`;
      input.disabled = true;
      submitBtn.disabled = true;
    } else {
      counterEl.textContent = `${remaining} of ${MAX_QUESTIONS} questions remaining`;
    }
  }

  fetch(`${API_URL}/api/remaining`)
    .then((r) => r.json())
    .then(
      (d: {
        questionsRemaining?: number;
      }) => {
        updateCounter(
          d.questionsRemaining ??
            MAX_QUESTIONS,
        );
      },
    )
    .catch(() => {
      updateCounter(MAX_QUESTIONS);
    });

  clearBtn?.addEventListener(
    "click",
    () => {
      sessionStorage.removeItem(
        STORAGE_KEY,
      );
      threadEl.innerHTML = "";
      questionsRemaining =
        MAX_QUESTIONS;
      limitReached = false;
      input.disabled = false;
      submitBtn.disabled = false;
      updateCounter(MAX_QUESTIONS);
    },
  );

  form.addEventListener(
    "submit",
    async (e) => {
      e.preventDefault();
      const question =
        input.value.trim();
      if (
        !question ||
        questionsRemaining <= 0
      )
        return;

      const messages = loadHistory();
      messages.push({
        role: "user",
        text: question,
      });
      saveHistory(messages);

      appendUserBubble(question);
      input.value = "";
      setLoading(true);

      const thinkingEl =
        appendThinkingBubble();
      const email =
        "leimeter.joaquin@gmail.com";

      try {
        const res = await fetch(
          `${API_URL}/api/ask`,
          {
            method: "POST",
            headers: {
              "Content-Type":
                "application/json",
            },
            body: JSON.stringify({
              question,
            }),
          },
        );

        const data =
          (await res.json()) as {
            answer?: string;
            questionsRemaining?: number;
            error?: string;
          };

        if (res.status === 429) {
          limitReached = true;
          updateCounter(0);
          const limitText = `Hey! You've reached the limit. If you have more questions you can send me an email on: ${email}`;
          messages.push({
            role: "ai",
            text: limitText,
            isError: true,
          });
          saveHistory(messages);
          typewriteInto(
            thinkingEl,
            limitText,
            true,
            () => {
              const full =
                thinkingEl.textContent ??
                "";
              const idx =
                full.lastIndexOf(email);
              if (idx === -1) return;
              thinkingEl.textContent =
                full.slice(0, idx);
              const span =
                document.createElement(
                  "span",
                );
              span.textContent = email;
              span.className =
                "ai-chat__limit-email";
              span.dataset.tooltip =
                "Copy to clipboard";
              span.addEventListener(
                "click",
                async () => {
                  await navigator.clipboard.writeText(
                    email,
                  );
                  span.dataset.tooltip =
                    "Copied!";
                  setTimeout(() => {
                    span.dataset.tooltip =
                      "Copy to clipboard";
                  }, 2000);
                },
              );
              thinkingEl.appendChild(
                span,
              );
            },
          );
        } else if (res.status === 503) {
          const errText =
            "AI is temporarily unavailable. Please try again in a moment.";
          messages.push({
            role: "ai",
            text: errText,
            isError: true,
          });
          saveHistory(messages);
          typewriteInto(
            thinkingEl,
            errText,
            true,
          );
        } else if (!res.ok) {
          const errText =
            "Something went wrong. Please try again.";
          messages.push({
            role: "ai",
            text: errText,
            isError: true,
          });
          saveHistory(messages);
          typewriteInto(
            thinkingEl,
            errText,
            true,
          );
        } else {
          const answer =
            data.answer ?? "";
          messages.push({
            role: "ai",
            text: answer,
          });
          saveHistory(messages);
          typewriteInto(
            thinkingEl,
            answer,
          );
          updateCounter(
            data.questionsRemaining ??
              0,
          );
        }
      } catch {
        const errText =
          "Unable to reach the server. Please try again later.";
        messages.push({
          role: "ai",
          text: errText,
          isError: true,
        });
        saveHistory(messages);
        typewriteInto(
          thinkingEl,
          errText,
          true,
        );
      } finally {
        setLoading(false);
      }
    },
  );
</script>

<style lang="scss">
  @use "../css/config" as *;

  .ai-chat {
    display: grid;
    gap: 0.5rem;
    width: 100%;
    max-width: 480px;
  }

  .ai-chat__box {
    border: 1px solid
      map-get($gorko-colors, "border");
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .ai-chat__thread {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    height: 320px;
    overflow-y: auto;
    padding: 1rem;
  }

  .ai-chat__input-area {
    border-top: 1px solid
      map-get($gorko-colors, "border");
    padding: 0.625rem 0.875rem;
  }

  :global(.ai-chat__bubble) {
    padding: 0.5rem 0.75rem;
    border-radius: 0.75rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: 85%;
    word-break: break-word;
  }

  :global(.ai-chat__bubble--user) {
    align-self: flex-start;
    background: map-get(
      $gorko-colors,
      "surface-alt"
    );
    color: map-get(
      $gorko-colors,
      "white"
    );
    border-bottom-left-radius: 0.25rem;
  }

  :global(.ai-chat__bubble--ai) {
    align-self: flex-end;
    color: map-get(
      $gorko-colors,
      "secondary"
    );
    border-bottom-right-radius: 0.25rem;
  }

  :global(.ai-chat__bubble--error) {
    color: map-get(
      $gorko-colors,
      "primary"
    );
  }

  :global(.ai-chat__bubble--thinking) {
    display: flex;
    align-items: center;
  }

  :global(.ai-chat__dots) {
    display: flex;
    gap: 0.25rem;

    span {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: map-get(
        $gorko-colors,
        "secondary"
      );
      animation: ai-chat-dot 1.2s
        ease-in-out infinite;

      &:nth-child(2) {
        animation-delay: 0.2s;
      }

      &:nth-child(3) {
        animation-delay: 0.4s;
      }
    }
  }

  @keyframes ai-chat-dot {
    0%,
    80%,
    100% {
      opacity: 0.3;
      transform: scale(0.8);
    }

    40% {
      opacity: 1;
      transform: scale(1);
    }
  }

  .ai-chat__form {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .ai-chat__prompt {
    font-family: monospace;
    font-size: 1rem;
    flex-shrink: 0;
    user-select: none;
  }

  .ai-chat__input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font: inherit;
    font-size: 0.9375rem;
    min-width: 0;

    &::placeholder {
      color: map-get(
        $gorko-colors,
        "muted"
      );
    }

    &:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
  }

  .ai-chat__submit {
    background: none;
    border: none;
    cursor: pointer;
    font: inherit;
    font-size: 1.1rem;
    padding: 0 0.25rem;
    flex-shrink: 0;
    transition: color 0.15s ease;

    &:hover:not(:disabled) {
      color: map-get(
        $gorko-colors,
        "primary"
      );
    }

    &:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }
  }

  .ai-chat__clear {
    background: none;
    border: none;
    border-left: 1px solid
      map-get($gorko-colors, "border");
    cursor: pointer;
    font: inherit;
    font-size: 1rem;
    padding: 0 0 0 0.5rem;
    flex-shrink: 0;
    opacity: 0.4;
    transition: opacity 0.15s ease;

    &:hover {
      opacity: 1;
    }
  }

  .ai-chat__counter {
    font-size: 0.8125rem;
    padding-inline: 0.25rem;
  }

  :global(.ai-chat__limit-email) {
    font-weight: 700;
    cursor: pointer;
    position: relative;

    &::after {
      content: attr(data-tooltip);
      position: absolute;
      bottom: calc(100% + 6px);
      left: 50%;
      transform: translateX(-50%);
      background: map-get(
        $gorko-colors,
        "surface-alt"
      );
      color: map-get(
        $gorko-colors,
        "secondary"
      );
      font-size: 0.75rem;
      font-weight: 400;
      white-space: nowrap;
      padding: 0.25rem 0.5rem;
      border-radius: 0.25rem;
      border: 1px solid
        map-get($gorko-colors, "border");
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.15s ease;
    }

    &:hover::after {
      opacity: 1;
    }
  }
</style>
