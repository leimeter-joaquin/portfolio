---

---

<footer id="contact" class="footer">
  <div
    class="footer__inner section-wrapper"
  >
    <div class="footer__info">
      <div class="footer__brand">
        <div class="footer__monogram">
          JL
        </div>
        <span
          class="footer__name color-white weight-bold"
          >Joaquin Leimeter</span
        >
      </div>
      <p class="color-muted">
        Open for freelance opportunities
        and full-time roles. Feel free
        to reach out if you have a
        project in mind.
      </p>
      <a
        href="mailto:leimeter.joaquin@gmail.com"
        class="color-primary weight-bold footer__email"
        >leimeter.joaquin@gmail.com</a
      >
    </div>

    <nav
      class="footer__social"
      aria-label="Social links"
    >
      <a
        href="https://github.com"
        aria-label="GitHub"
        class="footer__social-link color-secondary"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 17.07 3.633 16.7 3.633 16.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.605-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"
          ></path>
        </svg>
      </a>
      <a
        href="https://linkedin.com"
        aria-label="LinkedIn"
        class="footer__social-link color-secondary"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path>
        </svg>
      </a>
      <a
        href="https://twitter.com"
        aria-label="Twitter"
        class="footer__social-link color-secondary"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"
          ></path>
        </svg>
      </a>
    </nav>
  </div>
  <div
    class="footer__bottom section-wrapper"
  >
    <span
      class="footer__copy color-muted"
      >© 2026 Joaquin Leimeter. Built
      with care.</span
    >
  </div>
</footer>

<style lang="scss">
  @use "../css/config" as *;

  .footer {
    background: var(--bg-surface-alt);
    border-top: 1px solid
      var(--glass-border-subtle);
  }

  .footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: 4rem;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer__info {
    display: grid;
    gap: 1rem;
    max-width: 460px;
  }

  .footer__brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .footer__monogram {
    width: 30px;
    height: 30px;
    border-radius: 0.5rem;
    background: var(--accent);
    display: grid;
    place-items: center;
    font-size: 0.6875rem;
    font-weight: 800;
    color: #fff;
    box-shadow: 0 4px 12px
      rgba(var(--accent-rgb), 0.35);
    flex-shrink: 0;
  }

  .footer__name {
    font-size: 0.9375rem;
  }

  .footer__info p {
    font-size: 0.875rem;
    line-height: 1.75;
  }

  .footer__email {
    font-size: 0.9375rem;
    text-decoration: none;
    transition: opacity 0.2s ease;

    &:hover {
      opacity: 0.75;
    }
  }

  .footer__social {
    display: flex;
    gap: 1.5rem;
  }

  .footer__social-link {
    opacity: 0.7;
    transition: opacity 0.2s ease;

    &:hover {
      opacity: 1;
    }
  }

  .footer__bottom {
    padding-block: 1.5rem;
    border-top: 1px solid
      var(--glass-border-subtle);
    text-align: center;
  }

  .footer__copy {
    font-size: 0.75rem;
    opacity: 0.5;
  }
</style>
