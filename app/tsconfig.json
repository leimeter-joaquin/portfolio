{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@components/*": [
        "src/components/*"
      ],
      "@data/*": ["src/data/*"],
      "@css/*": ["src/css/*"]
    }
  }
}
